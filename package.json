{
  "name": "graphql-starred-repositories",
  "private": true,
  "scripts": {
    "build": "parcel build index.html",
    "start": "parcel index.html --open",
    "lint": "yarn eslint",
    "format": "yarn eslint --fix && yarn stylelint --fix && yarn prettier --write",
    "eslint": "eslint --cache './**/*.{ts,tsx}'",
    "prettier": "prettier './**/*.{md,js,ts,tsx,json}'",
    "stylelint": "stylelint --cache --syntax css-in-js './src/**/*.{ts,tsx}'",
    "graphql-codegen": "graphql-codegen --config codegen.yml --require dotenv/config",
    "postinstall": "yarn graphql-codegen"
  },
  "dependencies": {
    "graphql-tag": "2.10.1",
    "lens.ts": "https://github.com/tbo/lens.ts#master",
    "react": "16.12.0",
    "react-dom": "16.12.0",
    "urql": "1.8.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "1.20.1",
    "@graphql-codegen/fragment-matcher": "1.17.8",
    "@graphql-codegen/introspection": "1.18.1",
    "@graphql-codegen/typescript": "1.21.0",
    "@graphql-codegen/typescript-operations": "1.17.14",
    "@graphql-codegen/typescript-urql": "1.17.7",
    "@types/node": "12.19.16",
    "@types/react": "16.14.3",
    "@types/react-dom": "16.9.10",
    "@typescript-eslint/eslint-plugin": "2.34.0",
    "@typescript-eslint/parser": "2.34.0",
    "dotenv": "8.2.0",
    "eslint": "6.8.0",
    "eslint-config-airbnb": "18.2.1",
    "eslint-config-prettier": "6.15.0",
    "eslint-plugin-import": "2.22.1",
    "eslint-plugin-jsx-a11y": "6.4.1",
    "eslint-plugin-react": "7.22.0",
    "eslint-plugin-react-hooks": "2.5.1",
    "graphql": "14.7.0",
    "npm-run-all": "4.1.5",
    "parcel-bundler": "1.12.4",
    "prettier": "1.19.1",
    "stylelint": "13.10.0",
    "stylelint-config-prettier": "8.0.2",
    "stylelint-config-recess-order": "2.3.0",
    "stylelint-config-standard": "19.0.0",
    "typescript": "3.9.9"
  }
}
